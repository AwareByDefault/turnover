{
  "name": "turnover",
  "version": "0.1.0",
  "description": "Decorator-first REST framework for Bun — inject your dependencies, mount controllers, and let them rest.",
  "type": "module",
  "license": "MIT",
  "author": "Jake Uskoski <jake@awarebydefault.com>",
  "homepage": "https://github.com/AwareByDefault/turnover#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AwareByDefault/turnover.git"
  },
  "bugs": {
    "url": "https://github.com/AwareByDefault/turnover/issues"
  },
  "keywords": [
    "bun",
    "rest",
    "framework",
    "decorators",
    "dependency-injection",
    "di",
    "controller",
    "http",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/framework"
  ],
  "sideEffects": [
    "./dist/metadata.js"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^7.0.2"
  }
}
